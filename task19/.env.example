# MCP Pipeline Server (Task 19)

# Bearer-токен для авторизации клиентов
MCP_TOKEN=pipeline-mcp-2026

# DeepSeek API
DEEPSEEK_KEY=sk-your-key-here
DEEPSEEK_URL=https://api.notifikatai.ru/api/deepseek

# Путь к SQLite базе бота Task18
DB_PATH=/opt/challenge-bot/challenge.db

# Куда сохранять результаты пайплайна
SAVE_DIR=/opt/mcp-pipeline/results

# Порт сервера
MCP_PORT=8002

# Nginx hostname (для DNS rebinding protection)
ALLOWED_HOST=api1.notifikatai.ru
